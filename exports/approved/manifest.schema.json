{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alpha-forge.local/schemas/manifest-v3.json",
  "title": "Alpha Forge approved strategy manifest (v3+)",
  "description": "Canonical schema for manifests in exports/approved/. ADR-0031 + ADR-0066 addendum (tracking fields + short-side entry rules).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "strategy_name",
    "alpha_forge_commit",
    "approved_at",
    "approval_adr",
    "engine",
    "approved_combos",
    "validation",
    "execution_hints",
    "runtime_contract",
    "runtime_invariants",
    "expansion_policy"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^v(3|[4-9]|[1-9][0-9]+)(\\.[0-9]+)*$",
      "description": "v3 or higher. v1 and v2 manifests are legacy and not validated by this schema."
    },
    "strategy_name": { "type": "string", "minLength": 1 },
    "alpha_forge_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "description": "Full 40-char git sha of alpha_forge at approval time."
    },
    "approved_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },
    "approval_adr": {
      "type": "string",
      "pattern": "^decisions/\\d{4}-.+\\.md$"
    },
    "prior_approval_adr": {
      "type": "string",
      "pattern": "^decisions/\\d{4}-.+\\.md$"
    },
    "supersedes": { "type": "string" },
    "complementary_to": {
      "type": "string",
      "description": "ADR-0066: filename of sibling manifest (e.g. v3→v2 or v4→v3) for cross-reference."
    },
    "live_status": {
      "type": "string",
      "enum": ["pending_audit", "active", "deprecated"],
      "description": "ADR-0066: activation lifecycle state."
    },
    "live_status_since": {
      "type": "string",
      "format": "date-time",
      "description": "ADR-0066: timestamp of last live_status transition."
    },
    "audit_adr": {
      "type": "string",
      "pattern": "^decisions/\\d{4}-.+\\.md$",
      "description": "ADR-0066: pointer to pre-registered audit ADR."
    },
    "audit_closeout_adr": {
      "type": "string",
      "pattern": "^decisions/\\d{4}-.+\\.md$",
      "description": "ADR-0066: pointer to audit closeout ADR."
    },
    "series_source": {
      "type": "object",
      "additionalProperties": true,
      "description": "ADR-0066: opaque metadata about the research series that produced this manifest."
    },
    "engine": {
      "type": "object",
      "required": ["family", "params"],
      "properties": {
        "family": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "approved_combos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "timeframe",
          "validation_window",
          "window_tag",
          "oos_trades",
          "oos_sharpe",
          "oos_mdd_pct",
          "oos_pnl_pct"
        ],
        "properties": {
          "symbol": { "type": "string", "pattern": "^[A-Z]{2,10}USDT$" },
          "timeframe": { "type": "string", "pattern": "^(1m|5m|15m|30m|1h|4h|1d)$" },
          "validation_window": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.\\.\\d{4}-\\d{2}-\\d{2}$"
          },
          "window_tag": { "type": "string", "pattern": "^\\d{4}-H[12]$" },
          "oos_trades": { "type": "integer", "minimum": 30 },
          "oos_sharpe": { "type": "number", "minimum": 1.0 },
          "oos_mdd_pct": { "type": "number", "minimum": 0, "maximum": 20 },
          "oos_pnl_pct": { "type": "number", "exclusiveMinimum": 0 },
          "approved_in": { "type": "string", "pattern": "^v\\d+$" },
          "regime": { "type": "string", "description": "ADR-0066: qualitative regime label." },
          "cost_stress_ratio_min": { "type": "number", "minimum": 0, "maximum": 1 },
          "mc_p5_final_equity": { "type": "number" },
          "source_tag": { "type": "string" },
          "source_run_id": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "method",
        "cost_model_baseline_pct",
        "cost_model_stress_fee_plus_10_pct",
        "cost_stress_ratio_min",
        "seed_monte_carlo"
      ],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "cost_model_baseline_pct": { "type": "number", "exclusiveMinimum": 0 },
        "cost_model_stress_fee_plus_10_pct": { "type": "number", "exclusiveMinimum": 0 },
        "cost_stress_ratio_min": { "type": "number", "minimum": 0.95 },
        "seed_monte_carlo": { "type": "integer" },
        "notes": { "type": "string" }
      }
    },
    "execution_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position_sizing",
        "notional_per_trade_quote_ccy",
        "exit_rule",
        "regime_gate",
        "causal_invariant",
        "signal_arbitration"
      ],
      "properties": {
        "position_sizing": { "const": "fixed_notional_per_trade" },
        "notional_per_trade_quote_ccy": { "type": "number", "exclusiveMinimum": 0 },
        "entry_rule": { "type": "string", "minLength": 1 },
        "entry_rule_long": { "type": "string", "minLength": 1 },
        "entry_rule_short": { "type": "string", "minLength": 1 },
        "exit_rule": { "type": "string", "minLength": 1 },
        "regime_gate": { "type": "string", "minLength": 1 },
        "causal_invariant": { "type": "string", "minLength": 1 },
        "signal_arbitration": { "type": "string", "minLength": 1 },
        "reverse_on_signal": { "type": "string" }
      },
      "oneOf": [
        { "required": ["entry_rule"], "not": { "anyOf": [{ "required": ["entry_rule_long"] }, { "required": ["entry_rule_short"] }] } },
        { "required": ["entry_rule_long", "entry_rule_short"], "not": { "required": ["entry_rule"] } }
      ],
      "description": "ADR-0066: `entry_rule` singular OR both `entry_rule_long`+`entry_rule_short` (short-side post ADR-0051)."
    },
    "runtime_contract": {
      "const": "faithful",
      "description": "ADR-0030. Only 'faithful' is accepted in v3."
    },
    "runtime_invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_fill",
        "exit_fill",
        "sizing",
        "stop_loss",
        "signal_arbitration"
      ],
      "properties": {
        "entry_fill": { "const": "market_at_open_next_bar" },
        "exit_fill": { "const": "market_at_open_next_bar" },
        "sizing": { "const": "fixed_notional_literal" },
        "stop_loss": { "const": "disabled" },
        "signal_arbitration": { "const": "exit_wins_on_tie" }
      }
    },
    "disallow_sizing_modes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["snowball", "kelly_like", "martingale"]
      }
    },
    "disallow_sizing_reason": { "type": "string" },
    "expansion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "excluded_combos"],
      "properties": {
        "rule": { "type": "string", "minLength": 1 },
        "regime_dependence_note": { "type": "string" },
        "excluded_combos": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["symbol", "timeframe", "window_tag", "reason"],
            "properties": {
              "symbol": { "type": "string", "pattern": "^[A-Z]{2,10}USDT$" },
              "timeframe": { "type": "string", "pattern": "^(1m|5m|15m|30m|1h|4h|1d)$" },
              "window_tag": { "type": "string", "pattern": "^\\d{4}-H[12]$" },
              "reason": { "type": "string", "minLength": 1 },
              "source_tag": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
